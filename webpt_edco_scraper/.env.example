WEBPT_USERNAME=your.username
WEBPT_PASSWORD=your-password
WEBPT_COMPANY_ID=13829
WEBPT_HEADLESS=false

# Rate limits (lower = faster; too low may trigger WebPT WAF)
WEBPT_PDF_DELAY_SEC=0.5
WEBPT_PDF_TIMEOUT_SEC=60
WEBPT_ACTION_DELAY_SEC=0
WEBPT_PATIENT_PAGE_SIZE=50
WEBPT_TIMEZONE=US/Eastern

# Parallel download (Phase 2 after discovery-only export)
WEBPT_PARALLEL_WORKERS=12
WEBPT_MAX_CONCURRENT_PDFS=24

# Disable OCR during fast parallel download; run ocr-batch-test later
WEBPT_OCR_ENABLED=false
