WAYSTAR_USER=your_username
WAYSTAR_PASS=your_password
WAYSTAR_CUST_ID=
WAYSTAR_APP_ID=1
WAYSTAR_TRANSACTION_DAYS=30
# Single fallback when question does not match WAYSTAR_SECURITY_ANSWERS:
WAYSTAR_SECURITY_ANSWER=katy
# Question→answer map (substring match, case-insensitive; overrides built-in defaults):
WAYSTAR_SECURITY_ANSWERS=mother's maiden name=ahmed;first pet=katy
WAYSTAR_ACTION_DELAY_MIN=1.0
WAYSTAR_ACTION_DELAY_MAX=2.5
WAYSTAR_MFA_TIMEOUT_SEC=600
WAYSTAR_SLOW_MO_MS=100
WAYSTAR_CLAIM_FORM=CMS1500_0212
WAYSTAR_PDF_DELAY_SEC=1.5
# Transient network retry (navigation / API calls):
# WAYSTAR_NETWORK_RETRIES=3
# WAYSTAR_NETWORK_RETRY_DELAY_SEC=10
# Rejected claims calendar search (optional defaults when using --rejected):
# WAYSTAR_REJECTED_STATUS=12345
# WAYSTAR_TRANS_FROM=01/01/2025
# WAYSTAR_TRANS_TO=12/31/2026
# Full 90-day scrape example:
# WAYSTAR_TRANSACTION_DAYS=90
# python scraper.py --transaction-days 90 --download-pdfs --pdf-delay 2 --batch-claims 10000 --keep-browser-open
# python merge_exports.py output/claims_90d_{run_id}/
# Rejected claims 2025-2026 example:
# python scraper.py --rejected --trans-from 01/01/2025 --trans-to 12/31/2026 --download-pdfs --pdf-delay 2 --batch-claims 1000 --checkpoint-pages 50 --run-id rejected_2025_2026
# python merge_exports.py output/claims_rejected_rejected_2025_2026/
